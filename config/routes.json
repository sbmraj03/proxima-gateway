{
    "routes": [
        {
            "method": "GET",
            "path": "/api/users",
            "auth": true,
            "rateLimit": {
                "maxTokens": 5,
                "refillRate": 1
            },
            "targets": ["${BACKEND1_URL}", "${BACKEND2_URL}"]
        },
        {
            "method": "GET",
            "path": "/api/public",
            "auth": false,
            "rateLimit": {
                "maxTokens": 20,
                "refillRate": 5
            },
            "targets": ["${BACKEND1_URL}"]
        }
    ]
}